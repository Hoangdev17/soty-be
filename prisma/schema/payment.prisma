model TransactionSePay {
  id                 String   @id @map("_id")
  transactionId      String
  gateway            String
  transactionDate    DateTime
  accountNumber      String?
  subAccount         String?
  amountIn           Float    @default(0)
  amountOut          Float    @default(0)
  accumulated        Float    @default(0)
  code               String?
  transactionContent String?
  referenceNumber    String?
  body               String?
  createdAt          DateTime @default(now())
  payment            Payment?
  paymentId          String?  @unique

  @@map("transactions_sepay")
}

model FailedWebhookTransaction {
  id              String    @id @map("_id")
  paymentId       String // Nếu giao dịch liên quan đến Payment
  webhookSource   String // Nguồn webhook: "momo", "vnpay", "zalopay", etc.
  webhookId       String? // ID webhook từ provider (nếu có)
  // Thông tin giao dịch
  operationType   String // "CREATE", "UPDATE", "DELETE"
  transactionHash String? // Mã băm của giao dịch
  amount          Float? // Số tiền giao dịch
  currency        String? // Đơn vị tiền tệ
  // Trạng thái xử lý
  status          Int // 0: Pending, 1: Completed, 2: Failed, 3: Refunded
  processedAt     DateTime? // Thời điểm xử lý thành công
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  // Thông tin lỗi
  metadata        Json? // Thông tin bổ sung về giao dịch
  lastError       String?
  errorDetails    Json?

  @@map("failed_webhook_transaction")
}

model PlanBenefit {
  id              String   @id @map("_id")
  name            String // Benefit name (e.g., "AI Token Limit")
  displayName     String?
  description     String? // Detailed description
  type            String // Benefit type
  valueType       String // Value type
  unit            String? // Unit (e.g., "tokens", "GB", "users", "courses")
  category        String? // Category (e.g., "ai", "storage", "support", "feature")
  icon            String? // Icon for the benefit
  sortOrder       Int      @default(0) // Display order
  // Benefit values - EXTENSION
  booleanValue    Boolean? // For on/off features
  numberValue     Int? // For quantity limits
  stringValue     String? // For text-based values
  isUnlimited     Boolean  @default(false) // Unlimited flag
  // RESET CYCLE for benefits
  resetCycle      Int? // MONTHLY, WEEKLY, DAILY, NEVER
  // SPECIAL attributes
  isFeatureAccess Boolean  @default(false) // Grants feature access
  isQuantityLimit Boolean  @default(false) // Is a quantity limit
  isStorageLimit  Boolean  @default(false) // Is a storage limit
  // Metadata and state
  metadata        Json? // Store complex configuration
  isEnabled       Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
//   roleBenefitId String?
//   roleBenefit   UserRoleBenefit? @relation(fields: [roleBenefitId], references: [id])

//   @@unique([roleBenefitId, name])
//   @@unique([roleBenefitId, category, name])
  @@map("plan_benefits")
}
