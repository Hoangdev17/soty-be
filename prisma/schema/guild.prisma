// ================== ENUMS (CONFIG & TYPES) ==================

enum NotifLevel {
  ALL_MESSAGES
  ONLY_MENTIONS
}

enum ContentFilter {
  DISABLED
  MEMBERS_WITHOUT_ROLES
  ALL_MEMBERS
}

enum VerifyLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum NsfwLevel {
  DEFAULT
  EXPLICIT
  SAFE
  AGE_RESTRICTED
}

enum MfaLevel {
  NONE
  ELEVATED
}

enum PremiumTier {
  NONE
  TIER_1
  TIER_2
  TIER_3
}

enum ChannelType {
  GUILD_TEXT
  GUILD_VOICE
  GUILD_CATEGORY
  GUILD_STAGE_VOICE
  GUILD_FORUM
  GUILD_ANNOUNCEMENT
}

enum EventEntity {
  STAGE_INSTANCE
  VOICE
  EXTERNAL
}

enum EventStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELED
}

enum GuildType {
  PUBLIC
  PRIVATE
}

// ================== CORE MODELS ==================

model Guild {
  id          String   @id @map("_id")
  name        String
  icon        String?
  banner      String?
  splash      String?
  description String?

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id])
  deleted      Boolean @default(false)           // Cờ soft-delete
  guildType    GuildType @default(PUBLIC)        // Loại guild

  // CONFIG
  defaultMessageNotifications NotifLevel   @default(ONLY_MENTIONS)
  explicitContentFilter       ContentFilter @default(DISABLED)
  verificationLevel           VerifyLevel   @default(NONE)
  nsfwLevel                   NsfwLevel     @default(DEFAULT)
  mfaLevel                    MfaLevel      @default(NONE)

  // PREMIUM
  premiumTier               PremiumTier @default(NONE)
  premiumSubscriptionCount  Int         @default(0)
  premiumProgressBarEnabled Boolean     @default(false)

  // LIMITS
  maximumBitrate            Int?
  maxMembers                Int?
  maxPresences              Int?
  maxStageVideoChannelUsers Int?
  maxVideoChannelUsers      Int?

  // VANITY / WIDGET
  vanityURLCode   String?  @unique
  vanityURLUses   Int      @default(0)
  widgetEnabled   Boolean  @default(false)
  widgetChannelId String?  @unique
  widgetChannel   Channel? @relation("WidgetChannel", fields: [widgetChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // SYSTEM CHANNELS
  systemChannelId String?  @unique
  systemChannel   Channel? @relation("GuildSystemChannel", fields: [systemChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rulesChannelId String?  @unique
  rulesChannel    Channel? @relation("GuildRulesChannel", fields: [rulesChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  publicUpdatesChannelId String?  @unique
  publicUpdatesChannel Channel? @relation("GuildPublicUpdatesChannel", fields: [publicUpdatesChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  safetyAlertsChannelId String?  @unique
  safetyAlertsChannel  Channel? @relation("GuildSafetyAlertsChannel", fields: [safetyAlertsChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  systemChannelFlags Int @default(0)

  // META
  shardId   Int?
  available Boolean   @default(true)
  createdAt DateTime  @default(now())

  // RELATIONS
  channels Channel[]
  roles    Role[]
  members  GuildMember[]
  emojis   Emoji[]
  stickers Sticker[]
  invites  Invite[]
  bans     Ban[]
  events   ScheduledEvent[]

  @@index([ownerId])
  @@map("guild")
}

model Channel {
  id      String @id @map("_id")
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  name     String
  type     ChannelType
  topic    String?
  position Int?

  invites Invite[]
  events  ScheduledEvent[]

  parentId String?
  parent   Channel? @relation("ChannelParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  children Channel[] @relation("ChannelParent")

  // back-rel cho special channels
  widgetOfGuild        Guild? @relation("WidgetChannel")
  systemOfGuild        Guild? @relation("GuildSystemChannel")
  rulesOfGuild         Guild? @relation("GuildRulesChannel")
  publicUpdatesOfGuild Guild? @relation("GuildPublicUpdatesChannel")
  safetyAlertsOfGuild  Guild? @relation("GuildSafetyAlertsChannel")

  bitrate   Int?
  userLimit Int?

  @@index([guildId])
  @@index([guildId, type])
  @@index([guildId, parentId])
  @@index([guildId, name])
  @@map("channel")
}

model Role {
  id          String @id @map("_id")
  guildId     String
  name        String
  color       Int?
  hoist       Boolean @default(false)
  position    Int?
  permissions BigInt  @default(0)
  managed     Boolean @default(false)
  mentionable Boolean @default(false)

  guild   Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  members GuildMemberRole[]

  @@index([guildId])
  @@index([guildId, position])
  @@map("role")
}

model GuildMember {
  id                          String   @id @map("_id")
  guildId                     String
  userId                      String
  nick                        String?
  joinedAt                    DateTime?
  deaf                        Boolean  @default(false)
  mute                        Boolean  @default(false)
  pending                     Boolean  @default(false)
  communicationDisabledUntil  DateTime?

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roles GuildMemberRole[]

  @@unique([guildId, userId])
  @@index([guildId, joinedAt])
  @@map("guild_member")
}

model GuildMemberRole {
  id            String @id @map("_id")
  guildMemberId String
  roleId        String
  guildId       String

  guildMember GuildMember @relation(fields: [guildMemberId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([guildMemberId, roleId])
  @@index([guildId, roleId])
  @@index([guildId, guildMemberId])
  @@map("guild_member_role")
}

model Emoji {
  id        String @id @map("_id")
  guildId   String
  name      String
  animated  Boolean @default(false)
  available Boolean @default(true)
  creatorId String?

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, name])
  @@map("emoji")
}

model Sticker {
  id          String @id @map("_id")
  guildId     String
  name        String
  description String?
  tags        String?
  formatType  Int?
  available   Boolean @default(true)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, name])
  @@map("sticker")
}

model Invite {
  id        String   @id @map("_id")
  code      String   @unique
  guildId   String
  channelId String?
  inviterId String?
  uses      Int      @default(0)
  maxUses   Int?
  maxAgeSeconds Int?
  temporary Boolean  @default(false)
  createdAt DateTime @default(now())

  guild   Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, channelId])
  @@map("invite")
}

model Ban {
  id        String   @id @map("_id")
  guildId   String
  userId    String
  reason    String?
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId, createdAt])
  @@map("ban")
}

model ScheduledEvent {
  id        String   @id @map("_id")
  guildId   String
  channelId String?
  creatorId String?
  name      String
  description String?
  entityType EventEntity
  status    EventStatus @default(SCHEDULED)
  scheduledStartTime DateTime
  scheduledEndTime   DateTime?
  location  String?
  image     String?

  guild   Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, status])
  @@index([guildId, scheduledStartTime])
  @@map("scheduled_event")
}