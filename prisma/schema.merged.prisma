// Auto-generated schema (do not edit)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ===== user.prisma =====
model User {
  id               String   @id @map("_id")         // ID duy nhất của user. Dùng làm _id trong Mongo. 

  username         String   @unique                // Tên đăng nhập.
  passwordHash     String                          // Mật khẩu đã băm (hash) bằng bcrypt.

  email            String   @unique                // Thông tin email (object: {address, verified}).
  phone            Json?                            // Thông tin số điện thoại (object: {e164, verified}), có thể null.

  disabled         Boolean  @default(false)        // Đánh dấu tài khoản bị vô hiệu hóa (ban/lock).

  globalName       String?                          // Nickname toàn hệ thống (giống Discord global name).
  bio              String?                          // Tiểu sử/mô tả cá nhân (profile bio).
  avatar           String?                          // Lonk ảnh đại diện.
  banner           String?                          // Link ảnh banner.
  accentColor      Int?                             // Màu profile dạng số (RGB integer).
  hexAccentColor   String?                          // Màu profile dạng chuỗi hex (#RRGGBB).

  badges           Json[]                           // Mảng các huy hiệu (badge). Ví dụ: [{code: "EARLY_SUPPORTER", grantedAt: "..."}].
  premium          Json?                            // Thông tin subscription Nitro/Premium. 
                                                   // Ví dụ: {active: true, tier: 2, expiresAt: "..."}.

  presence         Json?                            // Trạng thái hiện diện (online/offline/idle/dnd) + custom status, activities.
  devices          Json[]                           // Danh sách thiết bị đăng nhập (web/ios/android), IP, lastActiveAt, pushToken...
  privacy          Json?                            // Cài đặt quyền riêng tư: allowDMFrom, friendRequest, showActivity, showOnlineStatus.
  settings         Json?                            // Cài đặt cá nhân: theme, locale, timezone, notifications, voice, UI.
  mfa              Json?                            // Cấu hình bảo mật 2FA: enabled, type (totp/webauthn), backupCodes.

  deleted          Boolean @default(false)          // Đánh dấu đã xóa (soft delete). Nếu true => account coi như bị xóa.
  deletedAt        DateTime?                        // Thời điểm xóa (soft delete).

  createdAt        DateTime @default(now())         // Thời điểm tạo user (Mongo tự set).
  updatedAt        DateTime @updatedAt              // Thời điểm cập nhật gần nhất (Prisma auto update mỗi lần save).

  @@map("user")                                    // Đặt tên collection trong Mongo là "user".
}
